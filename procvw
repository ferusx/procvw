#!/usr/local/bin/python3.13# SPDX-License-Identifier: BSD-3-Clause# Copyright (c) 2026 Markus Johnssonimport argparseimport sysimport json# Local importsfrom fetcher import ProcessFetcherfrom filters import ProcessFilter, ProcessSorterfrom printer import ProcessPrinterfrom tree_builder import ProcessTreeBuilderfrom formatter import ProcessFormatterfrom tree_formatter import ProcessTreeFormatterfrom utils import (    load_json_processes,    build_tree_json,    print_summary, limit_tree_nodes)# =========================================================# Class: CustomArgumentParser# =========================================================class CustomArgumentParser(argparse.ArgumentParser):    """    Custom argument parser that overrides the default exit behavior.    Purpose:        Prevent argparse from terminating the program abruptly with sys.exit()        when encountering errors or help messages.    Behavior:        - Prints the error/help message to stderr (if present)        - Raises SystemExit manually instead of exiting internally    Why:        This allows better control over program flow and makes it possible        to handle argument parsing errors more cleanly, especially in tools        where you may want to intercept or customize exit behavior.    """    def exit(self, status=0, message=None):        """        Override of argparse.ArgumentParser.exit().        Instead of calling sys.exit() directly, this method:        - Prints the message (if any)        - Raises SystemExit with the given status        Args:            status (int): Exit status code            message (str, optional): Message to print before exiting        """        if message:            self._print_message(message, sys.stderr)        raise SystemExit(status)# =========================================================# Entry# =========================================================class ProcVwApp:    """    Main application controller for procvw.    This class orchestrates the full processing pipeline:        Fetch → Filter → Sort → Format → Print    It serves as the central coordinator, delegating all actual work    to specialized components while keeping control flow predictable    and easy to follow.    Responsibilities:        - Parse and validate command-line arguments        - Coordinate data flow between core components        - Select and execute the appropriate output mode (table/tree/JSON)    Design Notes:        ProcVwApp intentionally avoids implementing heavy logic directly.        Each stage of processing is handled by dedicated modules to maintain        separation of concerns and simplify future extensions.    """    # ---------------------------------------------------------------------    # __init__    # ---------------------------------------------------------------------    def __init__(self):        """        Initialize the application.        This performs the initial setup phase by:            1. Parsing command-line arguments            2. Validating flag combinations and constraints        After initialization, the application is ready to execute the        processing pipeline via the run() method.        """        self.args = self._parse_args()        # Validate flags and argument combinations        self._validate_args()    # ---------------------------------------------------------------------    # Method: _parse_args    # ---------------------------------------------------------------------    def _parse_args(self):        """        Define and parse command-line arguments.        This method constructs the CLI interface using argparse and        returns a populated Namespace containing all user-specified        options.        Returns:            argparse.Namespace: Parsed command-line arguments.        Option Groups:            Filtering:                -u, --user            Filter by username                -p, --pid             Filter by process ID                -f, --cmd-filter      Filter by command name(s)            Sorting:                -s, --sort            Sort by cpu, mem, pid, rss, cmd, or thr                -b, --bottom          Reverse sort order            Output:                -n, --number          Limit number of displayed entries                --color               Enable ANSI color output                --raw                 Disable formatting (plain output)                --no-header           Hide column headers            View Modes:                --tree                Tree view (hierarchical)                --table               Table view (flat list)                --json                Output data in JSON format            Tree Enhancements:                --cpu-all             Show subtree CPU for all nodes                --cpu-threshold       Show subtree CPU above threshold only                --tree-depth          Limit tree depth                -g, --glyph-style     Select tree glyph style                --charset             Choose character set (ascii/utf8)            File Operations:                --save FILE           Save output to JSON                --load FILE           Load process data from JSON            Misc:                --all                 Include kernel/system processes                -w, --line-wrap       Allow COMMAND column to wrap                --show-path           Display full command path instead of name        """        parser = CustomArgumentParser(            prog="procvw",            description="BSD Process Viewer",            formatter_class=argparse.RawTextHelpFormatter        )        parser.add_argument(            "--all",            action="store_true",            help="Include kernel/system processes"        )        parser.add_argument(            "-b",            "--bottom",            action="store_true"        )        parser.add_argument(            "--color",            action="store_true"        )        parser.add_argument(            "--cpu-all",            action="store_true",            help="Show subtree CPU usage for all nodes (tree mode only)"        )        parser.add_argument(            "--cpu-threshold",            type=float,            help="Show subtree CPU only for nodes above threshold (tree mode only)"        )        parser.add_argument(            "-f",            "--cmd-filter",            nargs="+",            help="Filter processes by command name(s)"        )        parser.add_argument(            '-g',            "--glyph-style",            choices=["1", "2", "3"],            default=None,            help="Changes the glyph style in tree mode (tree mode only)"        )        parser.add_argument(            "--json",            action="store_true",            help="Output process data in JSON format"        )        parser.add_argument(            "-w",            "--line-wrap",            action="store_true",            help="Allow long COMMAND fields to wrap instead of being truncated"        )        parser.add_argument(            "--load",            metavar="FILE",            help="Load process tree from JSON file instead of live system"        )        parser.add_argument(            "--no-header",            action="store_true",            help="Do not display column headers plus line"        )        parser.add_argument(            "-n",            "--number",            type=int,            default=20        )        parser.add_argument(            "-p",            "--pid",            type=int        )        parser.add_argument(            "--prune",            type=int,            metavar="LEVEL",            help="Prune low-value branches (higher = more aggressive, tree mode only)"        )        parser.add_argument(            "--save",            metavar="FILE",            help="Save output to JSON file"        )        parser.add_argument(            "-s", "--sort",            default="cpu",            help="Sort by cpu, mem, pid, rss, cmd, thr, or stat"        )        parser.add_argument(            "-u",            "--user"        )        parser.add_argument(            "--table",            action="store_true",            help="Display processes in table view"        )        parser.add_argument(            "--tree",            action="store_true",            help="Display processes in tree view"        )        parser.add_argument(            "--tree-depth",            type=int,            help="Limit tree depth (1 = root only, tree mode only)"        )        parser.add_argument(            "--show-path",            action="store_true",            help="Show full command with arguments (tree mode only)"        )        parser.add_argument(            "--raw",            action="store_true",            help="Output raw, unformatted process data (no colors, no alignment)"        )        return parser.parse_args()    # ---------------------------------------------------------------------    # Method: _validate_args    # ---------------------------------------------------------------------    def _validate_args(self):        """        Validate command-line arguments and enforce flag constraints.        This method ensures that incompatible or invalid combinations of        arguments are detected early, preventing undefined behavior later        in the processing pipeline.        Validation covers:            - Mutually exclusive modes                (e.g. --tree vs --json, --table vs --tree)            - Mode-specific constraints                (e.g. --tree-depth and --glyph-style require --tree,                 --table is only valid with --load)            - Value sanity checks                (e.g. non-negative CPU thresholds, valid depth values)            - Input validation                (e.g. ensuring --load targets a .json file)            - Output compatibility                (e.g. --raw vs --color, tree mode vs line wrapping)        On failure, the application exits immediately with a descriptive        error message to guide the user.        This centralized validation step keeps downstream components        simpler by guaranteeing a consistent and valid configuration.        """        ## Tree mode plus JSON        if self.args.tree and self.args.json:            raise SystemExit("Error: --tree and --json cannot be used together")        ## Table vs tree view        if self.args.table and self.args.tree:            raise SystemExit("Error: Cannot use --table and --tree together")        ## Sorting issues        valid_sort = {"stat", "cpu", "mem", "pid", "rss", "thr", "cmd"}        if self.args.sort not in valid_sort:            valid = ", ".join(sorted(valid_sort))            raise SystemExit(                f"Error: Invalid sort key '{self.args.sort}'. "                f"Valid options: {valid}"            )        ## CPU threshold sanity        if self.args.cpu_threshold is not None and self.args.cpu_threshold < 0:            raise SystemExit("Error: --cpu-threshold must be >= 0")        ## Tree-depth sanity        if self.args.tree_depth is not None and self.args.tree_depth < 1:            raise SystemExit("Error: --depth must be >= 1")        ## On load JSON        if self.args.load:            if not self.args.load.endswith(".json"):                raise SystemExit("Error: --load expects a .json file")        ## Color vs raw        if self.args.raw and self.args.color:            raise SystemExit("Error: --color cannot be used with --raw")        ## Prune level sanity        if self.args.prune is not None and self.args.prune < 0:            raise SystemExit("Error: --prune must be >= 0")        ## Table mode...        if self.args.table:            ## vs --load            if not self.args.load:                raise SystemExit("Error: --table can only be used with --load")        if not self.args.tree:            ## --cpu-all should not be used with table mode            if self.args.cpu_all:                raise SystemExit("Error: --cpu-all is only valid with --tree")            ## --cpu-threshold should not be used with table mode            if self.args.cpu_threshold:                raise SystemExit("Error: --cpu-threshold is only valid with --tree")            ## Line wrap vs tree mode            if self.args.line_wrap:                raise SystemExit("Error: --line-wrap is only valid with --tree")            ## Glyph style vs not using tree mode            if self.args.glyph_style:                raise SystemExit("Error: --glyph-style is only valid with --tree")            ## Tree depth vs table            if self.args.tree_depth is not None:                raise SystemExit("Error: --tree-depth is only valid with --tree")            ## Prune requires tree mode            if self.args.prune is not None:                raise SystemExit("Error: --prune is only valid with --tree")    # ---------------------------------------------------------------------    # Method: run    # ---------------------------------------------------------------------    def run(self):        """        Execute the main application pipeline.        This method coordinates the full lifecycle of procvw execution,        from data acquisition to final output. It acts as the central        control flow for all supported modes and features.        Pipeline Overview:            1. Data Source                - Load process data from JSON (--load), or                - Fetch live system processes via ps(1)            2. Processing                - Apply filtering (user, pid, command)                - Apply sorting based on selected criteria            3. Optional Export                - Serialize current dataset to JSON (--save)                - Tree structure is preserved when exporting            4. View Selection                - Tree mode (--tree or implicit via --load)                - Table mode (default or --table)                - JSON output (--json)            5. Rendering                - Format output using appropriate formatter                - Respect flags such as --color, --number, and wrapping            6. Output                - Print formatted results to stdout                - Display summary information                - Confirm save/load operations        Behavior Notes:            - Tree mode requires the full dataset to preserve hierarchy            - When loading from JSON, tree mode is enabled by default              unless explicitly overridden by --table            - JSON output bypasses standard formatting and prints raw data            - The --number flag limits output after sorting (table mode)              or after tree construction (tree JSON mode)        Error Handling:            - File operations (load/save) are validated and will terminate              execution with a descriptive error on failure        This method intentionally keeps logic linear and explicit to ensure        predictability and ease of debugging.        """        saved_file = None        loaded_file = None        if self.args.load:            processes = load_json_processes(self.args.load)            loaded_file = self.args.load        else:            processes = ProcessFetcher.fetch(self.args)        processes = ProcessFilter.apply(processes, self.args)        processes = ProcessSorter.apply(processes, self.args)        if self.args.save:            filename = self.args.save            # Ensure .json extension            if not filename.endswith(".json"):                filename += ".json"            saved_file = filename            # Build tree from current processed dataset            all_processes = processes            if not self.args.all:                all_processes = [                    p for p in all_processes                    if not (p.pid == 11 and "idle" in p.command.lower())                ]            roots, children = ProcessTreeBuilder.build(all_processes)            data = build_tree_json(roots, children, self.args)            try:                with open(filename, "w") as f:                    json.dump(data, f, indent=2)            except Exception as e:                raise SystemExit(f"Error saving file: {e}")        if self.args.load and not self.args.table:            self.args.tree = True        if self.args.tree:            all_processes = processes            if not self.args.all:                all_processes = [                    p for p in all_processes                    if not (p.pid == 11 and "idle" in p.command.lower())                ]            roots, children = ProcessTreeBuilder.build(all_processes)            if self.args.json:                data = build_tree_json(roots, children, self.args)                if self.args.number:                    data = limit_tree_nodes(data, self.args.number)                json_output = json.dumps(data, indent=2)                if self.args.json or not self.args.save:                    print(json_output)                # COUNT NODES                def count_nodes(nodes):                    total = 0                    for n in nodes:                        if not n:                            continue                        total += 1                        total += count_nodes(n.get("children", []))                    return total                node_count = count_nodes(data)                print_summary(node_count, self.args.color)                return            # NORMAL TREE OUTPUT (ONLY REACHED IF NOT JSON)            lines = ProcessTreeFormatter.format(                processes,                all_processes,                self.args,                self.args.color            )        else:            if self.args.number:                processes = processes[: self.args.number]            if self.args.json:                data = [                    {                        "pid": p.pid,                        "ppid": p.ppid,                        "user": p.user,                        "command": p.command,                        "cpu": p.cpu,                        "mem": p.mem,                        "rss_mb": p.rss_mb,                        "threads": p.threads,                        "started": p.started,                        "time": p.time                    }                    for p in processes                ]                json_output = json.dumps(data, indent=2)                if self.args.save:                    with open(self.args.save, "w") as f:                        f.write(json_output)                if self.args.json or not self.args.save:                    print(json_output)                return            lines = ProcessFormatter.format(processes, self.args.color, self.args)        # Print to standard output        ProcessPrinter.print(lines)        ## Print a summary line below the table/tree view telling        ## how many processes/nodes were displayed        if self.args.tree:            print_summary(len(lines), self.args.color)        else:            print_summary(len(processes), self.args.color, mode="table")        # Print a confirmation of saved/loaded processes        if saved_file:            print(f"Saved entries to {saved_file}")        if loaded_file:            print(f"Loaded entries from {loaded_file}")        print(f"tree_depth → {self.args.tree_depth}")# =========================================================# Main Entry# =========================================================if __name__ == "__main__":    app = ProcVwApp()    app.run()